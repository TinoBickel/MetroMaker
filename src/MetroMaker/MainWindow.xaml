<Window x:Class="MetroMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MetroMaker.ViewModels"
        xmlns:converters="clr-namespace:MetroMaker.Converters"
        Title="MetroMaker - Metro Icon Creator"
        Width="900" Height="600"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <converters:IconKindToGeometryConverter x:Key="IconToGeometry"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     FontSize="14"
                     VerticalContentAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  Suchen... (z.B. delete, papierkorb, edit)"
                                                           Foreground="Gray" FontSize="14" Margin="8,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Button Grid.Column="1" Content="Clear" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding ClearSearchCommand}"/>
        </Grid>

        <!-- Result Count -->
        <TextBlock Grid.Row="1" Margin="0,6,0,6" Foreground="Gray">
            <Run Text="Gefunden: "/><Run Text="{Binding ResultCount, Mode=OneWay}"/><Run Text=" Icons"/>
        </TextBlock>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Icon Grid -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding FilteredIcons}"
                     SelectedItem="{Binding SelectedIcon}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     BorderThickness="1" BorderBrush="#DDD">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="56" Height="68" Margin="2" Padding="4"
                                ToolTip="{Binding}">
                            <StackPanel HorizontalAlignment="Center">
                                <Viewbox Width="36" Height="36">
                                    <Path Data="{Binding Converter={StaticResource IconToGeometry}}"
                                          Stroke="#333333" StrokeThickness="0.8"
                                          Fill="Transparent"
                                          Stretch="Uniform" Width="24" Height="24"/>
                                </Viewbox>
                                <TextBlock Text="{Binding}" FontSize="8"
                                           HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="52" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Preview Panel -->
            <Border Grid.Column="1" Margin="12,0,0,0" BorderThickness="1" BorderBrush="#DDD" Padding="12">
                <StackPanel>
                    <TextBlock Text="Vorschau" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                    <!-- Large Preview -->
                    <Border Width="128" Height="128" HorizontalAlignment="Center"
                            Background="#F8F8F8" BorderThickness="1" BorderBrush="#EEE">
                        <Image Source="{Binding PreviewImage}" RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="None"/>
                    </Border>

                    <!-- Icon Name -->
                    <TextBlock Text="{Binding SelectedIcon}" HorizontalAlignment="Center"
                               Margin="0,8,0,12" FontSize="11" Foreground="#666"/>

                    <!-- Actual Size Preview -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="24x24:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                        <Border Width="24" Height="24" Background="#F0F0F0" BorderThickness="1" BorderBrush="#DDD">
                            <Image Source="{Binding ActualSizePreview}" RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="None"/>
                        </Border>
                    </StackPanel>

                    <Separator Margin="0,0,0,12"/>

                    <!-- Export Section -->
                    <TextBlock Text="Export" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock Text="Dateiname:" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ExportFilename, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,4" FontSize="12" VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text=".png" VerticalAlignment="Center"
                                   Margin="4,0,0,0" Foreground="Gray" FontSize="12"/>
                    </Grid>
                    <Button Content="Exportieren" Padding="8,8" Margin="0,12,0,0"
                            Command="{Binding ExportCommand}" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Margin="0,8,0,0" Padding="4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#666"/>
        </Border>
    </Grid>
</Window>
